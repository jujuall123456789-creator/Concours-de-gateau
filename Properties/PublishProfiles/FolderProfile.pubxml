<?xml version="1.0" encoding="utf-8"?>
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishDir>bin\Release\net8.0-windows\publish\win-x64\</PublishDir>
    <PublishProtocol>FileSystem</PublishProtocol>
    <_TargetId>Folder</_TargetId>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    
    <!-- 🟢 Dépendant du framework (puisque tes utilisateurs l'ont déjà) -->
    <SelfContained>false</SelfContained>
    
    <!-- 🟢 On garde le fichier unique pour que ce soit propre -->
    <PublishSingleFile>true</PublishSingleFile>
    
    <!-- 🟢 Pas de fichiers de debug (.pdb) inutiles -->
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
    
    <PublishReadyToRun>false</PublishReadyToRun>
  </PropertyGroup>
</Project>